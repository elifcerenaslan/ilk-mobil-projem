{
  "expo": {
    "name": "Nyota Focus",
    "slug": "nyota-focus",
    "scheme": "nyotafocus",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "userInterfaceStyle": "light",
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#FAF0E6"
      },
      "package": "com.nyota.focusapp"
    },
    "plugins": [
      "expo-router",
