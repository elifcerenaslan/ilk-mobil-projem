          "image": "./assets/images/icon.png",
          "imageWidth": 200
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "adef58c7-ecd2-4b1c-b29a-3a039823f2d9"
      }
    }
  }
